# MLflow Configuration
# Copy this file to .env.mlflow for local development

# =============================================================================
# POSTGRESQL CONFIGURATION (Backend Store)
# =============================================================================
# MLflow uses PostgreSQL to store experiment metadata, runs, parameters, metrics
POSTGRES_USER=mlflow_user
POSTGRES_PASSWORD=mlflow_password_change_in_production
POSTGRES_DB=mlflow_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# S3-COMPATIBLE STORAGE CONFIGURATION (Artifact Store)
# =============================================================================
# MLflow uses S3-compatible storage for model artifacts, plots, and files

# For Local Development (MinIO)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_BUCKET_NAME=mlflow-artifacts

# For Production (Cloudflare R2)
# AWS_ACCESS_KEY_ID=your_r2_access_key_id
# AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
# MLFLOW_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# MLFLOW_BUCKET_NAME=mlflow-artifacts-prod

# =============================================================================
# MLFLOW SERVER CONFIGURATION
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
MLFLOW_ARTIFACT_ROOT=s3://${MLFLOW_BUCKET_NAME}/mlflow-artifacts

# Server Host and Port
MLFLOW_HOST=0.0.0.0
MLFLOW_PORT=5000

# Enable artifact serving through MLflow server
MLFLOW_SERVE_ARTIFACTS=true

# =============================================================================
# AUTHENTICATION (Optional - for Production)
# =============================================================================
# Uncomment to enable basic authentication
# MLFLOW_AUTH_CONFIG_PATH=/path/to/auth_config.ini

# =============================================================================
# RAILWAY PRODUCTION CONFIGURATION
# =============================================================================
# For Railway deployment, use these environment variables:
# 
# MLFLOW_TRACKING_URI=https://mlflow-production.up.railway.app
# MLFLOW_BACKEND_STORE_URI=${{Postgres.DATABASE_URL}}
# MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts-prod/mlflow-artifacts
# AWS_ACCESS_KEY_ID=${{R2_ACCESS_KEY_ID}}
# AWS_SECRET_ACCESS_KEY=${{R2_SECRET_ACCESS_KEY}}
# MLFLOW_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# 
# Note: Railway provides DATABASE_URL automatically when you add PostgreSQL addon

# =============================================================================
# BACKEND APPLICATION CONFIGURATION
# =============================================================================
# These variables should also be set in your backend .env file
# so the FastAPI application can connect to MLflow

# Backend should use the same MLFLOW_TRACKING_URI
# MLFLOW_TRACKING_URI=http://localhost:5000  # Development
# MLFLOW_TRACKING_URI=https://mlflow-production.up.railway.app  # Production
