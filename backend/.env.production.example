# Backend Production Environment Variables for Railway
# Copy this file to configure your Railway deployment
# NEVER commit actual production values to version control
# See CONFIG.md for detailed documentation

# =============================================================================
# RAILWAY DEPLOYMENT NOTES
# =============================================================================
# Railway automatically provides:
# - DATABASE_URL (when PostgreSQL addon is attached)
# - REDIS_URL (when Redis addon is attached)
# 
# You must manually configure:
# - All authentication secrets
# - Cloudflare R2 credentials
# - CORS origins
# - Optional services (email, monitoring)
#
# Set these in Railway Dashboard > Your Service > Variables tab
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION (Required - Auto-provided by Railway PostgreSQL addon)
# =============================================================================
# Railway automatically sets DATABASE_URL when you attach PostgreSQL addon
# Format: postgresql://user:password@host:port/database
# You may need to convert to asyncpg format:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=${DATABASE_URL}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# REDIS CONFIGURATION (Required - Auto-provided by Railway Redis addon)
# =============================================================================
# Railway automatically sets REDIS_URL when you attach Redis addon
# Format: redis://:password@host:port
REDIS_URL=${REDIS_URL}
REDIS_CACHE_TTL=3600

# =============================================================================
# CELERY CONFIGURATION (Required)
# =============================================================================
# Use the same Redis instance with different database numbers
# Railway Redis URL typically doesn't include /0, so append it
CELERY_BROKER_URL=${REDIS_URL}/1
CELERY_RESULT_BACKEND=${REDIS_URL}/2

# =============================================================================
# AUTHENTICATION CONFIGURATION (Required - MUST SET MANUALLY)
# =============================================================================
# CRITICAL: Generate a secure random key with: openssl rand -hex 32
# This key is used to sign JWT tokens - keep it secret!
# NEVER use the example value below in production!
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_STRING_MINIMUM_32_CHARACTERS_LONG
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
PASSWORD_BCRYPT_ROUNDS=12

# =============================================================================
# ENCRYPTION CONFIGURATION (Required - MUST SET MANUALLY)
# =============================================================================
# AES-256-GCM encryption key for sensitive fields (customerID, PaymentMethod)
# Generate with: python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; key = AESGCM.generate_key(bit_length=256); print(base64.b64encode(key).decode('utf-8'))"
# NEVER use the example value below in production!
ENCRYPTION_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY

# =============================================================================
# CLOUDFLARE R2 OBJECT STORAGE (Required - MUST SET MANUALLY)
# =============================================================================
# Get credentials from Cloudflare R2 dashboard:
# 1. Go to Cloudflare Dashboard > R2 > Overview
# 2. Create API token with read/write permissions
# 3. Note your Account ID from the R2 dashboard
# 4. Create buckets: churn-models, churn-reports, churn-exports
#
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_BUCKET_MODELS=churn-models
S3_BUCKET_REPORTS=churn-reports
S3_BUCKET_EXPORTS=churn-exports
S3_REGION=auto

# =============================================================================
# MLFLOW CONFIGURATION (Required)
# =============================================================================
# Deploy MLflow as a separate Railway service or use managed MLflow
# If deploying on Railway, use the internal service URL
MLFLOW_TRACKING_URI=https://mlflow.yourdomain.com
MLFLOW_EXPERIMENT_NAME=churn-prediction-prod

# =============================================================================
# APPLICATION CONFIGURATION (Required)
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# =============================================================================
# CORS CONFIGURATION (Required - MUST SET MANUALLY)
# =============================================================================
# Comma-separated list of allowed frontend origins
# 
# Production Mode (ENVIRONMENT=production):
#   - Uses explicit whitelist for security
#   - Only listed origins can access the API
#   - Include protocol (https://) and exact domain
#   - No trailing slashes
#   - Add all frontend domains (production, staging, custom domains)
#
# Examples:
#   Single domain: https://churn-prediction.vercel.app
#   Multiple domains: https://churn-prediction.vercel.app,https://www.yourdomain.com,https://app.yourdomain.com
#
# Include your Vercel production domain(s)
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# MONITORING AND OBSERVABILITY (Optional)
# =============================================================================
# Jaeger endpoint for distributed tracing (OTLP gRPC)
# If using Railway, deploy Jaeger as a separate service
# Leave empty to disable tracing
JAEGER_ENDPOINT=
PROMETHEUS_ENABLED=true

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# Configure SMTP for email notifications
# For Gmail: Use App Passwords (not your regular password)
# For SendGrid: Use API key as password with username "apikey"
# Leave empty to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# RAILWAY-SPECIFIC CONFIGURATION
# =============================================================================
# Railway automatically provides these variables:
# - PORT: The port your service should listen on (Railway assigns this)
# - RAILWAY_ENVIRONMENT: The environment name (production, staging, etc.)
# - RAILWAY_SERVICE_NAME: Your service name
# - RAILWAY_PROJECT_NAME: Your project name
#
# Your FastAPI app should bind to 0.0.0.0:${PORT}
# Railway handles HTTPS termination, so your app uses HTTP internally
# =============================================================================
