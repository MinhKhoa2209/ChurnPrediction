# Backend Environment Variables
# Copy this file to .env and update values for your environment
# See CONFIG.md for detailed documentation

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://churn_user:churn_password@localhost:5432/churn_prediction
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# REDIS CONFIGURATION (Required)
# =============================================================================
# Redis connection string for caching
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_CACHE_TTL=3600

# =============================================================================
# CELERY CONFIGURATION (Required)
# =============================================================================
# Redis connection strings for Celery task queue
# Use different Redis databases (1, 2) to separate concerns
CELERY_BROKER_URL=redis://:redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_password@localhost:6379/2

# =============================================================================
# AUTHENTICATION CONFIGURATION (Required)
# =============================================================================
# JWT secret key - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
PASSWORD_BCRYPT_ROUNDS=12

# =============================================================================
# OAUTH CONFIGURATION (Optional - Google login)
# =============================================================================
# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=218374097232-ujj8fmpg4icfvjqdpllcb0ff2r99t3i.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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e



# =============================================================================
# ENCRYPTION CONFIGURATION (Required)
# =============================================================================
# AES-256-GCM encryption key for sensitive fields (customerID, PaymentMethod)
# Generate with: python -c "from cryptography.hazmat.primitives.ciphers.aead import AESGCM; import base64; key = AESGCM.generate_key(bit_length=256); print(base64.b64encode(key).decode('utf-8'))"
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-change-in-production

# =============================================================================
# OBJECT STORAGE CONFIGURATION (Required)
# =============================================================================
# MinIO for local development, Cloudflare R2 for production
# Local MinIO: http://localhost:9000
# Production R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_MODELS=models
S3_BUCKET_REPORTS=reports
S3_BUCKET_EXPORTS=exports
S3_REGION=us-east-1

# =============================================================================
# APPLICATION CONFIGURATION (Optional)
# =============================================================================
# Environment: development, staging, production, test
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# =============================================================================
# CORS CONFIGURATION (Required)
# =============================================================================
# Comma-separated list of allowed origins
# 
# Development Mode (ENVIRONMENT=development):
#   - Automatically accepts all localhost variations (localhost, 127.0.0.1, any port)
#   - The CORS_ORIGINS list below is used as a fallback
#   - You can access the API from http://localhost:3000, http://127.0.0.1:3000, etc.
#
# Production Mode (ENVIRONMENT=production):
#   - Uses explicit whitelist from CORS_ORIGINS
#   - Only listed origins are accepted for security
#   - Include protocol (http:// or https://) and exact domain
#   - No trailing slashes
#
# Examples:
#   Development: http://localhost:3000,http://localhost:3001
#   Production: https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# MONITORING AND OBSERVABILITY (Optional)
# =============================================================================
# Jaeger endpoint for distributed tracing (OTLP gRPC)
# Leave empty to use console exporter (development)
# Production: http://jaeger:4317
JAEGER_ENDPOINT=
PROMETHEUS_ENABLED=true

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# Leave empty to disable email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@churnprediction.com
