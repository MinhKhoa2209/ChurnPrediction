# Docker Compose Environment Variables
# Copy this file to .env and update values for your environment
# This file is used by docker-compose.yml for local development

# =============================================================================
# POSTGRESQL CONFIGURATION
# =============================================================================
POSTGRES_USER=churn_user
POSTGRES_PASSWORD=churn_password
POSTGRES_DB=churn_prediction
POSTGRES_PORT=5432

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# =============================================================================
# MINIO CONFIGURATION (S3-compatible storage)
# =============================================================================
# MinIO is used for local development as a Cloudflare R2 replacement
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
BACKEND_PORT=8000
PYTHON_VERSION=3.13

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_PORT=3000
NODE_VERSION=20

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
# Generate with: openssl rand -hex 32
# This should match the JWT_SECRET_KEY in backend/.env
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Development: Backend accepts all localhost variations (localhost, 127.0.0.1, any port)
# Production: Use explicit whitelist of allowed origins (comma-separated)
# Example for production: CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
