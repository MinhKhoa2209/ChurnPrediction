# Production Environment Variables
# Copy this file to .env.production and update with your production values
# NEVER commit .env.production to version control
# See backend/CONFIG.md for detailed documentation

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================
# Use managed PostgreSQL: Railway, AWS RDS, Google Cloud SQL, etc.
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# =============================================================================
# REDIS CONFIGURATION (Required)
# =============================================================================
# Use managed Redis: Railway, AWS ElastiCache, Google Cloud Memorystore, etc.
REDIS_URL=redis://:password@host:6379/0
REDIS_CACHE_TTL=3600

# =============================================================================
# CELERY CONFIGURATION (Required)
# =============================================================================
# Use different Redis databases for broker and result backend
CELERY_BROKER_URL=redis://:password@host:6379/1
CELERY_RESULT_BACKEND=redis://:password@host:6379/2

# =============================================================================
# AUTHENTICATION CONFIGURATION (Required)
# =============================================================================
# CRITICAL: Generate a secure random key with: openssl rand -hex 32
# This key is used to sign JWT tokens - keep it secret!
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
PASSWORD_BCRYPT_ROUNDS=12

# =============================================================================
# CLOUDFLARE R2 OBJECT STORAGE (Required)
# =============================================================================
# Get credentials from Cloudflare R2 dashboard
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_BUCKET_MODELS=churn-models
S3_BUCKET_REPORTS=churn-reports
S3_BUCKET_EXPORTS=churn-exports
S3_REGION=us-east-1

# =============================================================================
# MLFLOW CONFIGURATION (Required)
# =============================================================================
# Use managed MLflow deployment or Railway
MLFLOW_TRACKING_URI=https://mlflow.yourdomain.com
MLFLOW_EXPERIMENT_NAME=churn-prediction

# =============================================================================
# APPLICATION CONFIGURATION (Required)
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# =============================================================================
# CORS CONFIGURATION (Required)
# =============================================================================
# Comma-separated list of allowed frontend origins
# Include all production domains
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
RATE_LIMIT_PER_MINUTE=100

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# Configure SMTP for email notifications
# For Gmail: Use App Passwords (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# FRONTEND CONFIGURATION (For reference)
# =============================================================================
# These are set in the frontend deployment (Vercel)
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
