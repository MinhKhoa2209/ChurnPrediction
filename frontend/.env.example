# Frontend Environment Variables
# Copy this file to .env.local for local development
# See https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# =============================================================================
# API CONFIGURATION (Required)
# =============================================================================
# Backend API base URL
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_V1_PREFIX=/api/v1

# =============================================================================
# WEBSOCKET CONFIGURATION (Required)
# =============================================================================
# WebSocket URL for real-time updates
# Development: ws://localhost:8000
# Production: wss://api.yourdomain.com
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# =============================================================================
# AUTHENTICATION CONFIGURATION (Required)
# =============================================================================
# Auth provider: better-auth or auth-js
NEXT_PUBLIC_AUTH_PROVIDER=better-auth

# =============================================================================
# OAUTH CONFIGURATION (Optional - Google login)
# =============================================================================
# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: Must match the Client ID from Google Cloud Console
NEXT_PUBLIC_GOOGLE_CLIENT_ID=218374097232-ujj8fmpg4icfvjqdpllcb0ff2r99t3i.apps.googleusercontent.com

# =============================================================================
# APPLICATION CONFIGURATION (Optional)
# =============================================================================
NEXT_PUBLIC_APP_NAME=Customer Churn Prediction Platform
NEXT_PUBLIC_APP_VERSION=1.0.0

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=false

# =============================================================================
# ANALYTICS CONFIGURATION (Optional)
# =============================================================================
# Google Analytics, Plausible, etc.
NEXT_PUBLIC_ANALYTICS_ID=

# =============================================================================
# ERROR TRACKING (Optional)
# =============================================================================
# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=
