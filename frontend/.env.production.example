# Frontend Production Environment Variables for Vercel
# Copy these values to Vercel Dashboard > Your Project > Settings > Environment Variables
# NEVER commit actual production values to version control

# =============================================================================
# VERCEL DEPLOYMENT NOTES
# =============================================================================
# Vercel automatically provides:
# - VERCEL: "1" (indicates running on Vercel)
# - VERCEL_ENV: "production", "preview", or "development"
# - VERCEL_URL: Auto-generated deployment URL
# - VERCEL_GIT_COMMIT_SHA: Git commit SHA
#
# You must manually configure:
# - Backend API URL (Railway backend URL)
# - WebSocket URL (Railway backend URL with wss://)
# - Optional services (analytics, error tracking)
#
# Set these in Vercel Dashboard > Your Project > Settings > Environment Variables
# Make sure to set the environment scope to "Production" for production values
# =============================================================================

# =============================================================================
# API CONFIGURATION (Required - MUST SET MANUALLY)
# =============================================================================
# Backend API base URL - Use your Railway backend deployment URL
# Format: https://your-backend-service.up.railway.app
# DO NOT include trailing slash
NEXT_PUBLIC_API_URL=https://your-backend-service.up.railway.app
NEXT_PUBLIC_API_V1_PREFIX=/api/v1

# =============================================================================
# WEBSOCKET CONFIGURATION (Required - MUST SET MANUALLY)
# =============================================================================
# WebSocket URL for real-time updates - Use your Railway backend URL with wss://
# Format: wss://your-backend-service.up.railway.app
# DO NOT include trailing slash
NEXT_PUBLIC_WS_URL=wss://your-backend-service.up.railway.app

# =============================================================================
# AUTHENTICATION CONFIGURATION (Required)
# =============================================================================
# Auth provider: better-auth or auth-js
NEXT_PUBLIC_AUTH_PROVIDER=better-auth

# =============================================================================
# APPLICATION CONFIGURATION (Optional)
# =============================================================================
NEXT_PUBLIC_APP_NAME=Customer Churn Prediction Platform
NEXT_PUBLIC_APP_VERSION=1.0.0

# =============================================================================
# FEATURE FLAGS (Optional)
# =============================================================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_EMAIL_NOTIFICATIONS=true

# =============================================================================
# ANALYTICS CONFIGURATION (Optional)
# =============================================================================
# Google Analytics, Plausible, or other analytics service
# Leave empty to disable analytics
NEXT_PUBLIC_ANALYTICS_ID=

# =============================================================================
# ERROR TRACKING (Optional - Recommended for Production)
# =============================================================================
# Sentry DSN for error tracking
# Get from Sentry Dashboard > Settings > Projects > Your Project > Client Keys (DSN)
# Leave empty to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=

# Sentry configuration (optional)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# VERCEL-SPECIFIC CONFIGURATION
# =============================================================================
# Vercel automatically provides these variables:
# - NEXT_PUBLIC_VERCEL_URL: Auto-generated deployment URL
# - NEXT_PUBLIC_VERCEL_ENV: Environment (production, preview, development)
# - NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA: Git commit SHA
#
# You can use these in your application if needed
# =============================================================================

# =============================================================================
# CUSTOM DOMAIN CONFIGURATION (Optional)
# =============================================================================
# If you have a custom domain configured in Vercel:
# 1. Add your domain in Vercel Dashboard > Your Project > Settings > Domains
# 2. Update CORS_ORIGINS in your Railway backend to include your custom domain
# 3. Update NEXT_PUBLIC_API_URL if you're using a custom domain for the backend
# =============================================================================
